page {
  height: 100vh;
  overflow: hidden;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #fffaf3;
}

.main-content {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.sidebar-wrapper {
  width: 180rpx;
  flex-shrink: 0;
  background: #f8f1e9;
}

.content-area {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.dish-card {
  margin-bottom: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(82, 50, 25, 0.08);
  overflow: hidden;
}

.dish-card-body {
  display: flex;
  padding: 20rpx;
  gap: 20rpx;
}

.dish-card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
}

.dish-card-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #f8efe5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.dish-card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a3426;
  margin-bottom: 8rpx;
}

.dish-card-desc {
  font-size: 26rpx;
  color: #9a8068;
  line-height: 1.5;
}

.dish-card-footer {
  display: flex;
  justify-content: flex-end;
  padding: 0 20rpx 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #4a3426;
  margin-bottom: 12rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #9a8068;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.cart-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(82, 50, 25, 0.1);
  z-index: 100;
}

.cart-bar-left {
  position: relative;
  margin-right: 20rpx;
}

.cart-count-badge {
  position: absolute;
  top: -12rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #e47435;
  color: #fff;
  font-size: 20rpx;
  padding: 0 8rpx;
}

.cart-bar-info {
  flex: 1;
}

.cart-bar-hint {
  color: #8c6a4d;
  font-size: 26rpx;
}

.cart-bar-right {
  flex-shrink: 0;
}
