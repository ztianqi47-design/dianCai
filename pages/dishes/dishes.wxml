<view class="page">
  <view class="hero">
    <view class="title">私房菜库</view>
    <view class="subtitle">维护大厨拿手菜，并决定今天哪些菜可以点。</view>
  </view>

  <view wx:if="{{user && user.role !== 'chef'}}" class="empty section">
    当前账号无菜库管理权限。
  </view>

  <block wx:if="{{!user || user.role === 'chef'}}">
    <view class="card section">
      <view class="section-title">新增菜品</view>
      <input class="input" placeholder="菜名" value="{{name}}" bindinput="onNameInput" />
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="input picker-input">{{category}}</view>
      </picker>
      <textarea
        class="textarea section"
        placeholder="简单介绍一下这道菜"
        value="{{description}}"
        maxlength="120"
        bindinput="onDescriptionInput"
      />
      <textarea
        class="textarea section"
        placeholder="记录这道菜的制作步骤，方便备餐时查看"
        value="{{method}}"
        maxlength="2000"
        bindinput="onMethodInput"
      />
      <view class="row section">
        <image class="dish-image" src="{{image}}" mode="aspectFill" wx:if="{{image}}"></image>
        <view class="dish-image" wx:else></view>
        <button class="button secondary" bindtap="chooseImage">上传图片</button>
      </view>
      <button class="button" style="width: 100%; margin-top: 20rpx;" bindtap="createDish">加入菜库</button>
    </view>

    <view class="section">
      <view class="section-title">菜品列表</view>
      <view wx:if="{{!dishes.length}}" class="empty">菜库还是空的</view>
      <view wx:for="{{dishes}}" wx:key="_id" class="card row">
        <image class="dish-image" src="{{item.image}}" mode="aspectFill" wx:if="{{item.image}}"></image>
        <view class="dish-image" wx:else></view>
        <view style="flex: 1;">
          <view>{{item.name}}</view>
          <view class="muted">{{item.category || "素菜"}}</view>
          <view class="muted" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="muted" wx:if="{{item.method}}">已保存做法</view>
          <view class="muted">{{item.isActive ? "今日已上架" : "今日未上架"}}</view>
        </view>
        <view class="dish-actions">
          <button class="button secondary small-button" bindtap="openMethodEditor" data-dish="{{item}}">
            编辑做法
          </button>
          <button class="button {{item.isActive ? 'ghost' : ''}} small-button" bindtap="toggleActive" data-dish="{{item}}">
            {{item.isActive ? "下架" : "上架"}}
          </button>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">待安排许愿</view>
      <view wx:if="{{!wishes.length}}" class="empty">没有待安排愿望</view>
      <view wx:for="{{wishes}}" wx:key="_id" class="card row">
        <view>{{item.content}}</view>
        <button class="button secondary" bindtap="convertWish" data-wish="{{item}}">转入菜库</button>
      </view>
    </view>

    <view wx:if="{{editingDishId}}" class="card section">
      <view class="section-title">编辑制作方式</view>
      <textarea
        class="textarea"
        placeholder="例如：1. 处理食材 2. 热锅炒制 3. 调味收汁"
        value="{{editingMethod}}"
        maxlength="2000"
        bindinput="onEditingMethodInput"
      />
      <view class="row section">
        <button class="button ghost" bindtap="closeMethodEditor">取消</button>
        <button class="button" bindtap="saveMethod">保存做法</button>
      </view>
    </view>
  </block>
</view>
