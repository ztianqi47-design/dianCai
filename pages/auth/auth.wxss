.mode-switch {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.mode-chip {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 84rpx;
  border-radius: 999rpx;
  background: #f8f1e9;
  color: #8c6a4d;
  font-weight: 600;
}

.mode-chip.active {
  background: #fff1e4;
  color: #e47435;
}

.primary-button {
  width: 100%;
  margin-top: 28rpx;
}
