<view class="page">
  <view class="hero">
    <view class="title">进入家庭小食堂</view>
    <view class="subtitle">先完成身份注册。大厨创建家庭，家庭成员使用邀请码加入。</view>
  </view>

  <view class="card section">
    <view class="mode-switch">
      <view class="mode-chip {{mode === 'member' ? 'active' : ''}}" data-mode="member" bindtap="onModeChange">
        家庭成员
      </view>
      <view class="mode-chip {{mode === 'chef' ? 'active' : ''}}" data-mode="chef" bindtap="onModeChange">
        大厨
      </view>
    </view>

    <view class="section-title">昵称</view>
    <input class="input" placeholder="给自己起个称呼" value="{{nickname}}" bindinput="onNicknameInput" />

    <block wx:if="{{mode === 'chef'}}">
      <view class="section-title section">家庭名称</view>
      <input class="input" placeholder="例如：张家小食堂" value="{{familyName}}" bindinput="onFamilyNameInput" />
    </block>

    <block wx:if="{{mode === 'member'}}">
      <view class="section-title section">邀请码</view>
      <input class="input" placeholder="输入大厨分享的邀请码" value="{{inviteCode}}" bindinput="onInviteCodeInput" />
    </block>

    <button class="button primary-button" loading="{{loading}}" bindtap="submitRegistration">
      {{mode === 'chef' ? '创建家庭并进入' : '加入家庭并进入'}}
    </button>
  </view>
</view>
