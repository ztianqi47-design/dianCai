.section .button {
  flex: 1;
}

.summary-card {
  cursor: pointer;
}

.method-text {
  white-space: pre-wrap;
  line-height: 1.8;
  color: #6d523d;
}

.method-modal-mask {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 28rpx;
  background: rgba(74, 52, 38, 0.38);
  box-sizing: border-box;
  z-index: 1200;
}

.method-modal {
  width: 100%;
  max-width: 680rpx;
  max-height: 68vh;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fffaf3;
  box-shadow: 0 18rpx 48rpx rgba(82, 50, 25, 0.16);
  box-sizing: border-box;
}

.method-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.method-modal-close {
  flex-shrink: 0;
  color: #e47435;
  font-size: 26rpx;
  font-weight: 600;
}

.method-modal-body {
  max-height: calc(68vh - 100rpx);
  margin-top: 20rpx;
}
