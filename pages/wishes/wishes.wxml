<view class="page">
  <view class="hero">
    <view class="title">想吃什么都可以许愿</view>
    <view class="subtitle">大厨看到后，可以把愿望变成私房菜库里的菜。</view>
  </view>

  <view class="card section">
    <input class="input" placeholder="例如：糖醋排骨" value="{{content}}" bindinput="onInput" />
    <button class="button" style="width: 100%; margin-top: 20rpx;" bindtap="submitWish">提交愿望</button>
  </view>

  <view class="section">
    <view class="section-title">愿望清单</view>
    <view wx:if="{{!loading && !wishes.length}}" class="empty">还没有人许愿</view>
    <view wx:for="{{wishes}}" wx:key="_id" class="card row">
      <view>
        <view>{{item.content}}</view>
        <view class="muted">{{item.isFulfilled ? "已安排" : "等待大厨安排"}}</view>
      </view>
      <view class="muted">{{item.createTimeText || ""}}</view>
    </view>
  </view>
</view>
