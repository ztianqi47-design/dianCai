page {
  --td-brand-color: #e47435;
  --td-brand-color-light: #fff1e4;
  --td-warning-color: #e47435;
  min-height: 100vh;
  background: #fffaf3;
  color: #4a3426;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 30rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero {
  padding: 34rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ffe1bd, #fff3df);
  box-shadow: 0 12rpx 30rpx rgba(151, 91, 39, 0.1);
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.4;
}

.subtitle {
  margin-top: 12rpx;
  color: #8c6a4d;
  line-height: 1.7;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  margin-bottom: 18rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.card {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 26rpx rgba(82, 50, 25, 0.08);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.muted {
  color: #9a8068;
  font-size: 26rpx;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #e47435;
  color: #ffffff;
  font-weight: 600;
  font-size: 28rpx;
}

.button.secondary {
  background: #fff1e4;
  color: #c7632a;
}

.button.ghost {
  background: #f8f1e9;
  color: #6d523d;
}

.input,
.textarea {
  width: 100%;
  min-height: 82rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: #fff7ee;
  box-sizing: border-box;
}

.textarea {
  min-height: 170rpx;
  padding-top: 22rpx;
  line-height: 1.6;
}

.dish-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 22rpx;
  background: #f8efe5;
}

.empty {
  padding: 50rpx 30rpx;
  border-radius: 24rpx;
  background: #ffffff;
  color: #9a8068;
  text-align: center;
}
